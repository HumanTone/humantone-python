# Force LF line endings for all text files across all platforms.
# Prevents CRLF issues on Windows for ruff format and similar tools.
* text=auto eol=lf

# Explicit overrides for safety
*.py    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.json  text eol=lf
*.txt   text eol=lf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
